{
  "manifest_version": 3,
  "name": "Proxy",
  "version": "1.1.4",
  "description": "Route browser traffic through your local proxy with a clean on/off toggle.",
  "host_permissions": [
    "<all_urls>"
  ],
  "permissions": [
    "proxy",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Proxy Settings",
    "default_icon": {
      "16": "image/icon16.png",
      "48": "image/icon48.png",
      "128": "image/icon128.png"
    }
  },
  "icons": {
    "16": "image/icon16.png",
    "48": "image/icon48.png",
    "128": "image/icon128.png"
  }
}